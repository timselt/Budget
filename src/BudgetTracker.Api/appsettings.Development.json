{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithEnvironmentName" ],
    "Properties": {
      "Application": "BudgetTracker.Api",
      "Environment": "Development"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5435;Database=budgettracker;Username=budgettracker;Password=budgettracker_dev_password;Include Error Detail=true"
  }
}
