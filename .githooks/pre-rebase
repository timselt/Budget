#!/bin/sh

set -eu

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "pre-rebase: Çalışma ağacı temiz değil."
  echo "Önce değişiklikleri commit edin veya açıklayıcı isimle stash alın."
  echo "Örnek: git stash push -m 'wip-ui-before-rebase'"
  exit 1
fi

if [ -n "$(git ls-files --others --exclude-standard)" ]; then
  echo "pre-rebase: İzlenmeyen dosyalar var."
  echo "Önce ekleyin, commit edin veya stash alın."
  exit 1
fi

exit 0
